{
  "name": "@quorum/solana-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Solana edge for Quorum: @sqds/multisig V4 + @jup-ag/api + @pythnetwork/hermes-client. Built on raw web3.js instead of solana-agent-kit so swap instructions can be wrapped in multisig vault transactions.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jup-ag/api": "^6.0.48",
    "@pythnetwork/hermes-client": "^3.1.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@sqds/multisig": "^2.1.4",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bigint-buffer",
      "bufferutil",
      "esbuild",
      "utf-8-validate"
    ]
  }
