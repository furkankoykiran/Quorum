# Quorum — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# --- Milestone 1: orchestrator ---
# LiteLLM-style `provider/model` id. Swap to benchmark any supported provider.
# Examples: deepseek/deepseek-chat, anthropic/claude-sonnet-4-6,
# openai/gpt-4o-mini, gemini/gemini-1.5-pro.
QUORUM_MODEL=deepseek/deepseek-chat

# Per-provider API keys. LiteLLM picks whichever one matches QUORUM_MODEL's
# prefix. Blank keys are ignored — only fill the providers you use.
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

ANTHROPIC_API_KEY=
# Custom Anthropic endpoint (proxy/gateway). Blank = default api.anthropic.com.
ANTHROPIC_BASE_URL=

OPENAI_API_KEY=
GEMINI_API_KEY=

# Set to 1 to force offline dummy tools for every specialist (same as --mock).
QUORUM_USE_MOCK=

# Set to 1 to flip the Tech agent onto the live freqtrade-mcp tool (requires
# FREQTRADE_* env vars below and a reachable Freqtrade REST API).
QUORUM_TECH_LIVE=

# --- Day 2: live MCP servers ---
# OmniWire-MCP reads its feed config from RSS_FEEDS. You can either point
# this at a URL that serves JSON, or inline the JSON directly. For local dev
# we load the committed default via:
#   export RSS_FEEDS="$(cat configs/omniwire_feeds.json)"
# Default config includes: CoinDesk, The Block, Bloomberg Markets, Decrypt
RSS_FEEDS={"sources":[{"id":"coindesk","name":"CoinDesk","url":"https://www.coindesk.com/arc/outboundfeeds/rss/","type":"rss","enabled":true},{"id":"the-block","name":"The Block","url":"https://www.theblock.co/rss.xml","type":"rss","enabled":true},{"id":"bloomberg-markets","name":"Bloomberg Markets","url":"https://feeds.bloomberg.com/markets/news.rss","type":"rss","enabled":true},{"id":"decrypt","name":"Decrypt","url":"https://decrypt.co/feed","type":"rss","enabled":true}],"configPollIntervalMs":60000,"requestTimeoutMs":10000,"sentinel":{"failureThreshold":3,"recoveryTimeoutMs":60000}}

# OmniWire-MCP entrypoint (optional; defaults to /root/OmniWire-MCP/dist/index.js).
# Clone + build from https://github.com/furkankoykiran/OmniWire-MCP if missing.
OMNIWIRE_MCP_ENTRY=

# freqtrade-mcp entrypoint (optional; defaults to /root/freqtrade-mcp/build/index.js).
FREQTRADE_MCP_ENTRY=

# freqtrade-mcp backend connection. All three are required for get_ohlcv_live
# to work; without them the Tech agent stays on the dummy tool.
FREQTRADE_API_URL=http://127.0.0.1:8082
FREQTRADE_USERNAME=Freqtrader
FREQTRADE_PASSWORD=changeme

# --- Milestone 2+: Solana edge (not required for Milestone 1) ---
# Solana RPC endpoint. For devnet use https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# Base58-encoded Solana keypair secret for the operator wallet (devnet only).
SOLANA_PRIVATE_KEY=

# Squads V4 multisig PDA (output of create-multisig.ts).
SQUADS_MULTISIG_PDA=

# Squads V4 vault PDA (index 0, derived from multisig PDA).
SQUADS_VAULT_PDA=

# Helius API key (Milestone 5, Flow agent on-chain enrichment).
HELIUS_API_KEY=
